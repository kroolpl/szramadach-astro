---
import { Hammer, Layers, ArrowRight } from "lucide-react";

// Teaser list of services for the homepage
const services = [
    {
        id: "SRV-01",
        icon: Hammer,
        title: "Montaż pokryć",
        desc: "Układamy dachówkę ceramiczną, betonową, blachodachówkę oraz gonty bitumiczne.",
    },
    {
        id: "SRV-02",
        icon: Layers,
        title: "Remonty i modernizacje",
        desc: "Wymiana starego dachu na nowy (np. usuwanie eternitu) oraz wzmacnianie więźby.",
    },
];
---

<section
    id="uslugi"
    class="space-y-16 relative bg-sheet-white border border-sheet-border technical-sheet-shadow p-8 lg:p-16 rounded-sm mt-24 lg:mt-40 scroll-mt-24 lg:scroll-mt-32 flex flex-col items-center"
>
    <div
        class="absolute -top-[32px] left-8 h-[32px] w-48 bg-sheet-white border border-sheet-border border-b-0 sheet-tab-clip px-4 flex items-center text-[11px] font-mono text-slate-ink font-bold tracking-wider"
    >
        REF: SERVICES_02
    </div>
    <div class="space-y-4 text-center w-full services-header opacity-0">
        <p
            class="font-mono text-accent-orange font-black uppercase tracking-[0.3em] text-[11px]"
        >
            02 // NASZA OFERTA
        </p>
        <h2
            class="text-4xl lg:text-5xl xl:text-6xl font-black uppercase tracking-tighter text-slate-ink"
        >
            Kompleksowe <span class="hidden sm:inline"><br /></span> rozwiązania
            dachowe
        </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-8 w-full">
        {
            services.map((row) => (
                <div class="service-card bg-sheet-white border border-sheet-border p-6 lg:p-8 flex flex-col gap-6 group relative overflow-hidden rounded-sm technical-sheet-shadow hover:-translate-y-1 hover:shadow-xl transition-all duration-300 opacity-0">
                    <div class="flex justify-between items-start">
                        <div class="flex items-center gap-4">
                            <div class="w-10 h-10 lg:w-12 lg:h-12 border-2 border-slate-ink flex items-center justify-center text-slate-ink group-hover:bg-accent-orange group-hover:text-white group-hover:border-accent-orange transition-all duration-300">
                                <row.icon size={20} />
                            </div>
                            <div>
                                <h3 class="text-lg lg:text-xl font-black uppercase tracking-tight text-slate-ink">
                                    {row.title}
                                </h3>
                                <p class="font-mono text-[9px] text-slate-ink/40 uppercase tracking-widest font-bold">
                                    {row.id} // TECHNICAL_SPEC
                                </p>
                            </div>
                        </div>
                    </div>

                    <div class="h-px bg-sheet-border w-full relative">
                        <div class="absolute top-0 left-0 h-full w-12 bg-accent-orange/80 group-hover:w-full transition-all duration-500 ease-out" />
                    </div>

                    <p class="text-slate-ink/70 font-medium text-sm lg:text-base leading-relaxed">
                        {row.desc}
                    </p>
                </div>
            ))
        }
    </div>

    <div class="services-footer mt-8 pt-8 w-full flex justify-center opacity-0">
        <a
            href="/oferta"
            class="group bg-slate-ink text-white font-black hover:bg-accent-orange px-8 py-5 uppercase tracking-[0.2em] text-[11px] lg:text-xs transition-all duration-300 technical-sheet-shadow flex items-center gap-4 relative overflow-hidden shrink-0"
        >
            <span class="relative z-10 hidden sm:inline">Przeglądaj</span>Pełną
            Ofertę
            <ArrowRight
                size={16}
                strokeWidth={2.5}
                className="group-hover:translate-x-1 transition-transform relative z-10"
            />
            <div
                class="absolute inset-0 opacity-[0.1] pointer-events-none z-0"
                style="background-image: linear-gradient(#ffffff 1px, transparent 1px), linear-gradient(90deg, #ffffff 1px, transparent 1px); background-size: 10px 10px;"
            >
            </div>
        </a>
    </div>
</section>

<script>
    import { animate, inView, stagger } from "motion";

    const initServices = () => {
        // Header reveal
        inView(".services-header", ({ target }) => {
            animate(
                target,
                { opacity: 1, y: [30, 0] },
                { duration: 0.8, easing: [0.22, 1, 0.36, 1] }
            );
        });

        // Staggered cards reveal
        inView(".service-card", ({ target }) => {
            animate(
                ".service-card",
                { opacity: 1, y: [30, 0] },
                { 
                    duration: 0.8, 
                    delay: stagger(0.15),
                    easing: [0.22, 1, 0.36, 1] 
                }
            );
        });

        // Footer reveal
        inView(".services-footer", ({ target }) => {
            animate(
                target,
                { opacity: 1, scale: [0.95, 1] },
                { duration: 0.6, delay: 0.3, easing: [0.22, 1, 0.36, 1] }
            );
        });
    };

    document.addEventListener('astro:page-load', initServices);
</script>
