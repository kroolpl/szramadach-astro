---
import Layout from "../../layouts/Layout.astro";
import { Navigation } from "../../components/react/Navigation";
import Footer from "../../components/Footer.astro";
import { BackgroundElements } from "../../components/react/BackgroundElements";
import { Sheets } from "../../components/react/Sheets";
import { FloatingEstimateButton } from "../../components/react/FloatingEstimateButton";
import {
    Hammer,
    Layers,
    Zap,
    Droplets,
    Wrench,
    ShieldCheck,
    Ruler,
    Truck,
} from "lucide-react";

// Extended list of services for the full Oferta page
const fullServices = [
    {
        id: "SRV-01",
        icon: Hammer,
        title: "Montaż pokryć dachowych",
        desc: "Kompleksowo układamy dachówkę ceramiczną, betonową, blachodachówkę oraz gonty bitumiczne, dbając o najwyższą precyzję i rygorystyczne normy technologiczne.",
    },
    {
        id: "SRV-02",
        icon: Layers,
        title: "Remonty i modernizacje",
        desc: "Specjalizujemy się w wymianie starych dachów na nowe (w tym bezpieczne usuwanie eternitu), renowacji poszyć i kompleksowym wzmacnianiu konstrukcji więźby.",
    },
    {
        id: "SRV-03",
        icon: Zap,
        title: "Pogotowie dekarskie 24/7",
        desc: "Zapewniamy błyskawiczne interwencje w przypadku awarii, uszkodzeń przez wichury czy ulewy na terenie Tarnowa i okolic.",
    },
    {
        id: "SRV-04",
        icon: Droplets,
        title: "Obróbki blacharskie i rynny",
        desc: "Precyzyjnie wykonujemy montaż zaawansowanych systemów rynnowych, szczelne wstawianie okien dachowych oraz estetyczne wykańczanie kominów.",
    },
    {
        id: "SRV-05",
        icon: ShieldCheck,
        title: "Izolacje termiczne i paroizolacje",
        desc: "Instalujemy nowoczesne systemy termoizolacji dachów (wełna, pianka PIR/PUR) oraz membrany dachowe z zachowaniem pełnej szczelności.",
    },
    {
        id: "SRV-06",
        icon: Wrench,
        title: "Więźby dachowe i konstrukcje",
        desc: "Projektowanie, cięcie i fachowy montaż drewnianych konstrukcji dachowych zgodnie z dokumentacją architektoniczną.",
    },
    {
        id: "SRV-07",
        icon: Ruler,
        title: "Audyty i kosztorysowanie",
        desc: "Profesjonalna ocena stanu technicznego dachu, darmowe pomiary dronem i tworzenie przejrzystych kosztorysów inwestorskich.",
    },
    {
        id: "SRV-08",
        icon: Truck,
        title: "Odśnieżanie dachów płaskich",
        desc: "Zimowe interwencje na obiektach wielkopowierzchniowych (hale, magazyny, bloki) zapobiegające przeciążeniom konstrukcji.",
    },
];
---

<Layout title="Nasza Oferta - SzramaDach Tarnów">
    <BackgroundElements client:load />

    <div class="max-w-[1440px] mx-auto p-4 lg:p-8 relative z-10">
        <Navigation client:load />

        <main class="space-y-24 lg:space-y-32 pt-16">
            <section id="pelna-oferta" class="space-y-16">
                <div class="space-y-4">
                    <p
                        class="font-mono text-accent-orange font-black uppercase tracking-[0.3em] text-[11px]"
                    >
                        02 // PEŁNA OFERTA
                    </p>
                    <h1
                        class="text-4xl lg:text-5xl xl:text-6xl font-black uppercase tracking-tighter text-slate-ink"
                    >
                        Technologie <br class="hidden sm:block" /> Pokryć Dachowych
                    </h1>
                    <p
                        class="text-slate-ink/70 font-medium text-lg lg:text-xl leading-relaxed max-w-3xl pt-4"
                    >
                        Od budowy konstrukcji od zera, przez zaawansowaną
                        termomodernizację, aż po szybkie interwencje awaryjne.
                        Zobacz pełen rygor naszych autoryzacji usługowych.
                    </p>
                </div>

                <div
                    class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8"
                >
                    {
                        fullServices.map((service) => (
                            <div class="bg-sheet-white border border-sheet-border p-6 lg:p-8 flex flex-col gap-6 group relative overflow-hidden rounded-sm technical-sheet-shadow hover:-translate-y-1 transition-transform duration-300">
                                <div class="flex justify-between items-start">
                                    <div class="w-12 h-12 border-2 border-slate-ink flex items-center justify-center text-slate-ink group-hover:bg-accent-orange group-hover:text-white group-hover:border-accent-orange transition-all duration-300">
                                        <service.icon
                                            size={24}
                                            strokeWidth={1.5}
                                        />
                                    </div>
                                    <div class="font-mono text-[9px] text-slate-ink/40 uppercase tracking-widest font-bold">
                                        ID: {service.id}
                                    </div>
                                </div>

                                <div>
                                    <h3 class="text-xl font-black uppercase tracking-tight text-slate-ink mb-3 group-hover:text-accent-orange transition-colors duration-300">
                                        {service.title}
                                    </h3>
                                    <div class="w-8 h-1 bg-accent-orange mb-6" />
                                    <p class="text-slate-ink/70 font-medium text-sm leading-relaxed">
                                        {service.desc}
                                    </p>
                                </div>

                                <div class="mt-auto pt-6 border-t border-dashed border-sheet-border/50 flex justify-between items-center opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                                    <span class="font-mono text-[10px] uppercase font-bold text-accent-orange">
                                        ZAPRENUMERUJ WYCENĘ
                                    </span>
                                    <div class="w-6 h-6 rounded-full bg-accent-orange/10 flex items-center justify-center text-accent-orange">
                                        &rarr;
                                    </div>
                                </div>
                            </div>
                        ))
                    }
                </div>

                <!-- CTA Banner -->
                <div
                    class="mt-24 p-8 lg:p-12 bg-slate-ink text-white rounded-sm technical-sheet-shadow flex flex-col lg:flex-row items-center justify-between gap-8 relative overflow-hidden"
                >
                    <div
                        class="absolute inset-0 opacity-[0.03] pointer-events-none"
                        style="background-image: linear-gradient(#ffffff 1px, transparent 1px), linear-gradient(90deg, #ffffff 1px, transparent 1px); background-size: 20px 20px;"
                    >
                    </div>
                    <div
                        class="relative z-10 space-y-4 max-w-2xl text-center lg:text-left"
                    >
                        <h2
                            class="text-3xl lg:text-4xl font-black uppercase tracking-tighter"
                        >
                            Gotowy do rozpoczęcia projektu?
                        </h2>
                        <p
                            class="text-white/80 text-sm lg:text-base font-medium font-mono"
                        >
                            Skontaktuj się z naszym zespołem technicznym, aby
                            otrzymać darmowy audyt i precyzyjny kosztorys.
                        </p>
                    </div>
                    <a
                        href="tel:+48500123456"
                        class="relative z-10 bg-accent-orange text-white font-black hover:bg-white hover:text-slate-ink px-8 py-5 uppercase tracking-[0.2em] text-[11px] lg:text-xs transition-all duration-300 shadow-xl w-full lg:w-auto text-center shrink-0"
                    >
                        Zleć Bezpłatną Wycenę
                    </a>
                </div>
            </section>
        </main>

        <Footer />
    </div>

    <Sheets client:load />
    <FloatingEstimateButton client:load />
</Layout>
