---
import { Calculator } from "lucide-react";
import { Image } from "astro:assets";
import heroImage from "../assets/images/hero-roof.png";
---

<section id="hero" class="relative pt-12 lg:pt-24 scroll-mt-24 lg:scroll-mt-32">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
        <div class="lg:col-span-7 space-y-8">
            <h1
                class="hero-title text-5xl lg:text-8xl font-black uppercase leading-[0.85] tracking-tighter text-slate-ink opacity-0"
            >
                Twój dach – <span class="text-accent-orange">nasza pasja.</span>
                Solidne dekarstwo.
            </h1>

            <p
                class="hero-subtitle text-lg lg:text-xl text-slate-ink/70 max-w-2xl font-medium leading-relaxed opacity-0"
            >
                Od drobnych napraw po kompleksowe krycie dachów. Zapewniamy
                bezpieczeństwo nad Twoją głową na lata w Tarnowie i okolicach.
            </p>

            <div class="hero-actions flex flex-wrap gap-4 opacity-0">
                <button
                    id="hero-estimate-btn"
                    class="bg-accent-orange text-white font-black px-8 py-5 uppercase text-sm tracking-widest shadow-xl flex items-center gap-3 rounded-sm hover:scale-[1.02] active:scale-[0.98] transition-all"
                >
                    <Calculator size={18} />
                    Darmowa wycena
                </button>
                <a
                    href="#realizacje"
                    class="border-2 border-slate-ink text-slate-ink font-black px-8 py-5 uppercase text-sm tracking-widest flex items-center gap-3 rounded-sm hover:scale-[1.02] hover:bg-slate-ink/5 active:scale-[0.98] transition-all"
                >
                    Nasze realizacje
                </a>
            </div>
        </div>

        <div class="lg:col-span-5 relative">
            <div
                class="hero-image-container aspect-square bg-gray-100 border border-sheet-border relative overflow-hidden rounded-sm technical-sheet-shadow opacity-0"
            >
                <div class="absolute inset-0 w-full h-full">
                    <Image
                        src={heroImage}
                        alt="Profesjonalny montaż dachu - SzramaDach Tarnów"
                        class="w-full h-full object-cover mix-blend-multiply opacity-80 grayscale-[30%]"
                        loading="eager"
                        format="webp"
                    />
                </div>
                <div
                    class="absolute inset-0 border-[20px] border-white/10 pointer-events-none"
                >
                </div>
                <div
                    class="absolute top-4 right-4 font-mono text-[10px] text-slate-ink/40 uppercase"
                >
                    IMG_REF: DT_HERO_01
                </div>
            </div>

            <div
                id="quality-badge"
                class="absolute -bottom-6 -left-6 bg-white border border-slate-ink p-6 shadow-2xl z-20 hidden lg:block opacity-0"
            >
                <div class="flex items-center gap-4">
                    <div
                        class="w-12 h-12 bg-accent-orange flex items-center justify-center text-white"
                    >
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            width="24"
                            height="24"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            class="lucide lucide-badge-check"
                            ><path
                                d="M3.85 8.62a4 4 0 0 1 4.78-4.77 4 4 0 0 1 6.74 0 4 4 0 0 1 4.78 4.78 4 4 0 0 1 0 6.74 4 4 0 0 1-4.77 4.78 4 4 0 0 1-6.75 0 4 4 0 0 1-4.78-4.77 4 4 0 0 1 0-6.76Z"
                            ></path><path d="m9 12 2 2 4-4"></path>
                        </svg>
                    </div>
                    <div>
                        <p
                            class="font-mono text-[10px] uppercase text-slate-ink/40 font-bold"
                        >
                            Quality_Seal
                        </p>
                        <p
                            class="font-black uppercase text-slate-ink leading-none"
                        >
                            100% Gwarancja
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<script>
    import { animate, spring } from "motion";
    import { isFormOpen } from "../stores/uiStore";

    const initHero = () => {
        // Entrance Animations
        const sequence = async () => {
            // Title reveal
            await animate(
                ".hero-title",
                { opacity: 1, y: [20, 0] },
                { duration: 0.8, easing: [0.22, 1, 0.36, 1] }
            );

            // Subtitle and actions stagger
            animate(
                ".hero-subtitle",
                { opacity: 1, y: [20, 0] },
                { duration: 0.8, delay: 0.1, easing: [0.22, 1, 0.36, 1] }
            );
            animate(
                ".hero-actions",
                { opacity: 1, y: [20, 0] },
                { duration: 0.8, delay: 0.2, easing: [0.22, 1, 0.36, 1] }
            );

            // Image container reveal
            animate(
                ".hero-image-container",
                { opacity: 1, scale: [1.05, 1] },
                { duration: 1.2, delay: 0.3, easing: [0.22, 1, 0.36, 1] }
            );

            // Quality badge reveal + float
            animate(
                "#quality-badge",
                { opacity: 1, x: [-20, 0] },
                { duration: 0.8, delay: 0.5, easing: [0.22, 1, 0.36, 1] }
            ).finished.then(() => {
                animate(
                    "#quality-badge",
                    { y: [0, -10, 0] },
                    { 
                        duration: 4, 
                        repeat: Infinity, 
                        easing: "ease-in-out" 
                    }
                );
            });
        };

        // Run sequence
        sequence();

        const btn = document.getElementById("hero-estimate-btn");
        btn?.addEventListener("click", () => {
            isFormOpen.set(true);
        });
    };

    // Initialize on first load and after every navigation
    document.addEventListener('astro:page-load', initHero);
</script>
