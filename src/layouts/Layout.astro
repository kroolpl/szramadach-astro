---
import { ClientRouter } from "astro:transitions";
import { Navigation } from "../components/react/Navigation";
import { BackgroundElements } from "../components/react/BackgroundElements";
import { Sheets } from "../components/react/Sheets";
import { FloatingEstimateButton } from "../components/react/FloatingEstimateButton";
import "../styles/global.css";

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="pl">
	<head>
		<meta charset="UTF-8" />
		<meta
			name="description"
			content="Profesjonalne usługi dekarskie w Tarnowie i okolicach - SzramaDach. Solidne dachy na lata."
		/>
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<ClientRouter />
	</head>
	<body>
		<div class="noise-overlay" transition:persist="noise"></div>

		<BackgroundElements client:load transition:persist="bg-elements" />

		<div class="max-w-[1440px] mx-auto p-4 lg:p-8 relative z-10">
			<Navigation client:load transition:persist="nav" />
			<slot />
		</div>

		<Sheets client:load transition:persist="sheets" />
		<FloatingEstimateButton client:load transition:persist="fab" />

		<style is:global>
			/* Any Astro-specific global styles can go here */
		</style>
	</body>
</html>
